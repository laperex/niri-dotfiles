	},

	// --- Token Color Customizations -----------------------------------------------
	"editor.tokenColorCustomizations": {
		"[Tokyo Night Pro]": {
			"textMateRules": []
		}
	},
	"editor.semanticTokenColorCustomizations": {
		"[Material Theme Ocean High Contrast]": {
			"rules": {}
		}
	},

	// --- Markdown -----------------------------------------------------------------
	"markdown-pdf.displayHeaderFooter": false,
	"markdown-pdf.format": "A4",
	"markdown-pdf.styles": ["markdown.css"],
	"markdownConverter.Document.HeaderFooterEnabled": false,
	"markdownConverter.Document.Paper.PaperFormat": { "Format": "A4" },
	"markdownConverter.Document.Paper.Margin": {
		"Bottom": "0.2cm",
		"Top": "0.2cm",
		"Left": "0.2cm",
		"Right": "0.2cm"
	},
	"markdown-preview-enhanced.enablePreviewZenMode": false,
	"markdown-preview-enhanced.codeBlockTheme": "darcula.css",
	"markdown-preview-enhanced.revealjsTheme": "black.css",
	"markdown-preview-enhanced.previewTheme": "github-dark.css",

	// --- Notebook / Jupyter -------------------------------------------------------
	"notebook.output.scrolling": true,
	"notebook.cellToolbarLocation": {
		"default": "right",
		"jupyter-notebook": "left"
	},
	"jupyter.askForKernelRestart": false,

	// --- Hardware / EDA -----------------------------------------------------------
	"digital-ide.welcome.show": false,
	"digital-ide.prj.vivado.install.path": "/opt/Xilinx/Vivado/2024.1/bin/",
	"EIDE.Repository.UseProxy": false,
	"EIDE.C51.INI.Path": "/home/laperex/.wine/drive_c/Keil_v5/C51/BIN/C51.exe",
	"KeilAssistant.Keil.HOME": {
		"MDK": "/home/laperex/.wine/drive_c/Keil_v5",
		"C51": "/home/laperex/.wine/drive_c/Keil_v5"
	},
	"stm32-for-vscode.armkmchainPath": false,
	"stm32-for-vscode.makePath": "/usr/bin/make",
	"stm32-for-vscode.openOCDPath": false,
	"STM32VSCodeExtension.productFinder.executablePath": "/usr/bin/stmcufinder",
	"STM32VSCodeExtension.projectCreator.executablePath": "/usr/bin/stm32cubemx",

	// --- Misc Extensions ---------------------------------------------------------
	"hediet.vscode-drawio.resizeImages": null,
	"hediet.vscode-drawio.theme": "min",
	"hediet.vscode-drawio.appearance": "dark",
	"gitlens.ai.experimental.openai.model": "gpt-4-1106-preview",
	"gitlens.ai.experimental.provider": "openai",
	"regex-previewer.enableCodeLens": true,
	"tabnine.experimentalAutoImports": true,
	"ppm-pgm-viewer-for-vscode.imagepreview.autoScalingMode": true,
	"ppm-pgm-viewer-for-vscode.imagepreview.hidePanel": true,
	"vscode-office.editorTheme": "Github Dark",
	"vscode-pets.theme": "forest",
	"vsicons.dontShowNewVersionMessage": true,
	"workbench.editorAssociations": {
		"{hexdiff}:/**/*.*": "hexEditor.hexedit",
		"*.o": "hexEditor.hexedit"
	},
	"powermode.enabled": false,
	"powermode.combo.counterEnabled": "hide",
	"powermode.combo.counterSize": 0,
	"powermode.explosions.gifMode": "restart",
	"powermode.presets": "flames",
	"powermode.shake.enabled": false,

	// --- Settings Cycle -----------------------------------------------------------
	"settings.cycle": [
		{
			"id": "lineNumbers",
			"values": [
				{
					"editor.folding": false,
					"editor.glyphMargin": false,
					"editor.lineNumbers": "off"
				},
				{
					"editor.folding": true,
					"editor.glyphMargin": true,
					"editor.lineNumbers": "on"
				}
			]
		},
		{
			"id": "tabVisibility",
			"values": [
				{ "workbench.editor.showTabs": "none" },
				{ "workbench.editor.showTabs": "multiple" }
			]
		}
	],

	// --- Telemetry (disabled) ----------------------------------------------------
	"telemetry.telemetryLevel": "off",
	"gitlens.telemetry.enabled": false,
	"dotnetAcquisitionExtension.enableTelemetry": false,
	"redhat.telemetry.enabled": false,

	// --- Updates (disabled) ------------------------------------------------------
	"update.mode": "none",

	// --- Sync Ignored Extensions -------------------------------------------------
	"settingsSync.ignoredExtensions": [
		"nowsci.glassit-linux",
		"marnix.tokyo-night-pro",
		"enkia.tokyo-night",
		"jeroen-meijer.shibuya",
		"shalldie.background",
		"carlos18mz.cyberpunk-2077-rebuild",
		"vscode.coffeescript"
	]
}