{
	// --- Appearance ---------------------------------------------------------------
	"workbench.colorTheme": "Material Theme Ocean High Contrast",
	"workbench.iconTheme": "material-icon-theme",
	"workbench.preferredHighContrastColorTheme": "Tokyo Night Pro",
	"material-icon-theme.folders.theme": "classic",
	"window.zoomLevel": 1,
	"window.zoomPerWindow": true,
	"window.titleBarStyle": "native",
	"window.customTitleBarVisibility": "never",
	"window.title": "${dirty}${rootPath}${separator}${activeEditorMedium}",
	"window.density.editorTabHeight": "compact",
	"window.dialogStyle": "native",

	// --- Window Behavior ---------------------------------------------------------
	"window.newWindowDimensions": "inherit",
	"window.openFilesInNewWindow": "on",
	"window.openFoldersInNewWindow": "on",
	"window.openWithoutArgumentsInNewWindow": "on",
	"window.restoreFullscreen": false,
	"window.restoreWindows": "all",

	// --- Editor: Font -------------------------------------------------------------
	"editor.fontFamily": "JetBrainsMono Nerd Font",
	"editor.fontWeight": "normal",
	"editor.fontLigatures": true,

	// --- Editor: Behavior ---------------------------------------------------------
	"editor.tabSize": 4,
	"editor.indentSize": "tabSize",
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"editor.trimAutoWhitespace": false,
	"editor.formatOnSave": false,
	"editor.cursorBlinking": "solid",
	"editor.cursorSmoothCaretAnimation": "on",
	"editor.smoothScrolling": true,
	"editor.stickyScroll.enabled": false,
	"editor.renderWhitespace": "none",
	"editor.roundedSelection": false,
	"editor.largeFileOptimizations": true,
	"editor.inlayHints.enabled": "off",
	"editor.semanticHighlighting.enabled": false,
	"editor.colorDecoratorsLimit": 5000,
	"editor.defaultColorDecorators": "auto",

	// --- Editor: UI ---------------------------------------------------------------
	"editor.lineNumbers": "on",
	"editor.glyphMargin": true,
	"editor.folding": true,
	"editor.foldingHighlight": true,
	"editor.minimap.enabled": false,
	"editor.minimap.autohide": false,
	"editor.minimap.maxColumn": 200,
	"editor.minimap.size": "proportional",
	"editor.scrollbar.vertical": "hidden",

	// --- Workbench ----------------------------------------------------------------
	"workbench.editor.showTabs": "none",
	"workbench.editor.empty.hint": "text",
	"workbench.editor.editorActionsLocation": "hidden",
	"workbench.activityBar.location": "hidden",
	"workbench.activityBar.iconClickBehavior": "toggle",
	"workbench.list.smoothScrolling": true,
	"workbench.tree.enableStickyScroll": false,
	"workbench.startupEditor": "none",
	"workbench.welcomePage.walkthroughs.openOnInstall": true,
	"workbench.commandPalette.experimental.enableNaturalLanguageSearch": true,
	"workbench.view.alwaysShowHeaderActions": true,
	"breadcrumbs.enabled": false,

	// --- Explorer -----------------------------------------------------------------
	"explorer.confirmDelete": false,
	"explorer.confirmDragAndDrop": false,
	"explorer.confirmPasteNative": false,

	// --- Files --------------------------------------------------------------------
	"files.autoSave": "afterDelay",
	"files.simpleDialog.enable": true,
	"files.refactoring.autoSave": false,
	"files.trimTrailingWhitespace": false,
	"files.associations": {
		"*.rmd": "markdown",
		"*.xci": "json"
	},

	// --- Terminal -----------------------------------------------------------------
	"terminal.integrated.defaultProfile.linux": "zsh",
	"terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
	"terminal.integrated.gpuAcceleration": "on",
	"terminal.integrated.smoothScrolling": true,
	"terminal.integrated.tabs.enabled": false,
	"terminal.integrated.enableImages": false,
	"terminal.integrated.enableMultiLinePasteWarning": false,
	"terminal.explorerKind": "integrated",
	"terminal.external.linuxExec": "alacritty",

	// --- Zen Mode -----------------------------------------------------------------
	"zenMode.centerLayout": false,
	"zenMode.fullScreen": false,
	"zenMode.hideActivityBar": true,
	"zenMode.hideLineNumbers": false,
	"zenMode.hideStatusBar": true,
	"zenMode.restore": true,
	"zenMode.showTabs": "none",
	"zenMode.silentNotifications": false,

	// --- Git ----------------------------------------------------------------------
	"git.autofetch": true,
	"git.confirmSync": false,
	"git.confirmEmptyCommits": false,
	"git.enableSmartCommit": true,
	"git.openRepositoryInParentFolders": "never",
	"git.useEditorAsCommitInput": false,
	"github.gitAuthentication": false,
	"githubPullRequests.createOnPublishBranch": "never",
	"git-graph.maxDepthOfRepoSearch": 0,

	// --- Diff Editor -------------------------------------------------------------
	"diffEditor.renderSideBySide": false,

	// --- Search -------------------------------------------------------------------
	"search.useIgnoreFiles": false,

	// --- Language: JavaScript / CSS -----------------------------------------------
	"[javascript]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"[css]": {
		"editor.defaultFormatter": "esbenp.prettier-vscode"
	},
	"prettier.tabWidth": 4,
	"javascript.updateImportsOnFileMove.enabled": "always",

	// --- Language: C/C++ ---------------------------------------------------------
	"C_Cpp.codeFolding": "enabled",
	"C_Cpp.formatting": "vcFormat",
	"C_Cpp.intelliSenseEngine": "disabled",
	"C_Cpp.maxCachedProcesses": null,
	"C_Cpp.suggestSnippets": false,
	"C_Cpp.vcFormat.newLine.beforeCatch": false,
	"C_Cpp.vcFormat.newLine.beforeElse": false,
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.block": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.function": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.lambda": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.namespace": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeOpenBrace.type": "sameLine",
	"C_Cpp.vcFormat.newLine.beforeWhileInDoWhile": false,
	"C_Cpp.default.includePath": [
		"${workspaceFolder}/**",
		"/usr/include/glib-2.0",
		"/lib/glib-2.0/include",
		"/usr/include/cairo",
		"/usr/include",
		"/usr/lib/",
		"/usr/share/sdcc/include"
	],

	// --- Language: Clangd --------------------------------------------------------
	"clangd.enableCodeCompletion": true,
	"clangd.detectExtensionConflicts": false,
	"clangd.path": "/home/laperex/.config/Code/User/globalStorage/llvm-vs-code-extensions.vscode-clangd/install/19.1.2/clangd_19.1.2/bin/clangd",

	// --- Language: SystemVerilog --------------------------------------------------
	"[verilog]": {
		"editor.defaultFormatter": "eirikpre.systemverilog"
	},
	"[systemverilog]": {
		"editor.fontLigatures": false,
		"editor.formatOnType": true,
		"editor.defaultFormatter": "eirikpre.systemverilog",
		"editor.quickSuggestions": {
			"comments": "on",
			"strings": "on",
			"other": "on"
		}
	},
	"[systemverilogheader]": {
		"editor.fontLigatures": false
	},
	"[verilogheader]": {
		"editor.fontLigatures": true
	},
	"[vhdl]": {
		"editor.formatOnType": true,
		"editor.quickSuggestions": {
			"comments": "on",
			"strings": "on",
			"other": "on"
		}
	},
	"systemverilog.disableIndexing": false,
	"systemverilog.enableIncrementalIndexing": true,
	"systemverilog.forceFastIndexing": false,
	"systemverilog.excludeIndexing": "**/build/**",
	"systemverilog.includeIndexing": ["**rtl/*.{sv,v,svh,vh}"],
	"systemverilog.parallelProcessing": 20,
	"systemverilog.documentSymbolsPrecision": "full",
	"systemverilog.maxLineCountIndexing": 40000,
	"systemverilog.formatCommand": "verible-verilog-format --indentation_spaces 4",
	"systemverilog.languageServer.path": "verible-verilog-ls",
	"systemverilog.languageServer.arguments": ["--rules_config_search"],
	"verilog.linting.linter": "xvlog",
	"verilog.linting.path": "/opt/Xilinx/Vivado/2024.1/bin/",
	"verilog.linting.xvlog.arguments": "-I /opt/Xilinx/Vivado/2024.1/data/xsim/system_verilog/uvm_include/uvm_macros.svh",

	// --- Language: Haskell -------------------------------------------------------
	"haskell.ghcupExecutablePath": "~/.ghcup/bin/ghcup",
	"haskell.manageHLS": "GHCup",

	// --- CMake -------------------------------------------------------------------
	"cmake.configureOnOpen": false,
	"cmake.loadCompileCommands": true,
	"cmake.outputLogEncoding": "auto",
	"cmake.revealLog": "focus",
	"cmake.showConfigureWithDebuggerNotification": false,
	"cmake.showOptionsMovedNotification": false,
	"cmake.pinnedCommands": [
		"workbench.action.tasks.configureTaskRunner",
		"workbench.action.tasks.runTask"
	],

	// --- Makefile ----------------------------------------------------------------
	"makefile.configureOnOpen": true,

	// --- APC Customize UI --------------------------------------------------------
	"apc.font.family": "JetBrainsMono Nerd Font",
	"apc.monospace.font.family": "JetBrainsMono Nerd Font",
	"apc.electron": {
		"backgroundColor": "rgba(0, 0, 0, 0.92)",
		"frame": false,
		"opacity": 1,
		"titleBarStyle": "hiddenInset",
		"transparent": true,
		"vibrancy": "ultra-dark",
		"visualEffectState": "active"
	},
	"apc.activityBar": {
		"size": 40,
		"itemSize": 40,
		"itemMargin": 0
	},
	"apc.imports": [
		"file:///home/laperex/.config/Code/User/custom.css"
	],
	"apc.stylesheet": {
		"*": "border-radius: 0px !important",
		".pane-header": "line-height: 13px !important",
		".monaco-pane-view .pane>.pane-header h3.title": "font-size: 13px !important",
		".quick-input-list .monaco-scrollable-element .monaco-list-rows": "padding: 0 0 !important; background-color: rgba(0, 0, 0, 0) !important;"
	},
	"apc.listRow": {
		"height": 22,
		"lists": [
			"customview-tree",
			"results",
			"open-editors",
			"explorer-folders-view",
			"outline-tree",
			"scm-view",
			"debug-view-content",
			"debug-breakpoints",
			"tree"
		]
	},
	"apc.header": {
		"compact": 18,
		"fontSize": 11
	},
	"apc.statusBar": {
		"fontSize": 11,
		"height": 18
	},

